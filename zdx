-- ========== WORKING SPEED SYSTEM (USES VECTORFORCE - BYPASSES ANTI-CHEAT) ==========
local vectorForce = nil
local forceAttachment = nil
local bodyVelocity = nil

local function applyWorkingSpeed(speed)
    local char = player.Character
    if not char or not speedActive then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    
    if not hrp or not hum then return end
    
    -- Method 1: Set WalkSpeed
    hum.WalkSpeed = speed
    
    -- Method 2: BodyVelocity (gentle, won't fling)
    if bodyVelocity then bodyVelocity:Destroy() end
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(5000, 0, 5000)
    bodyVelocity.P = 4000
    bodyVelocity.Parent = hrp
    
    -- Method 3: VectorForce (strong bypass)
    if vectorForce then vectorForce:Destroy() end
    if forceAttachment then forceAttachment:Destroy() end
    
    forceAttachment = Instance.new("Attachment")
    forceAttachment.Parent = hrp
    
    vectorForce = Instance.new("VectorForce")
    vectorForce.Attachment0 = forceAttachment
    vectorForce.ApplyAtCenterOfMass = true
    vectorForce.Parent = hrp
    
    currentSpeedVal = speed
end

local function updateWorkingMovement()
    local char = player.Character
    if not char or not speedActive then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    
    if not hrp or not hum then return end
    
    local moveDir = hum.MoveDirection
    local targetSpeed = currentSpeedVal
    
    -- Update WalkSpeed
    if hum.WalkSpeed ~= targetSpeed then
        hum.WalkSpeed = targetSpeed
    end
    
    -- Update BodyVelocity
    if bodyVelocity then
        if moveDir.Magnitude > 0.1 then
            bodyVelocity.Velocity = Vector3.new(moveDir.X * targetSpeed, 0, moveDir.Z * targetSpeed)
        else
            bodyVelocity.Velocity = bodyVelocity.Velocity * 0.85
        end
    end
    
    -- Update VectorForce
    if vectorForce then
        if moveDir.Magnitude > 0.1 then
            vectorForce.Force = Vector3.new(moveDir.X * targetSpeed * 100, 0, moveDir.Z * targetSpeed * 100)
        else
            vectorForce.Force = Vector3.new(0, 0, 0)
        end
    end
end

local function stopWorkingSpeed()
    if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
    if vectorForce then vectorForce:Destroy() vectorForce = nil end
    if forceAttachment then forceAttachment:Destroy() forceAttachment = nil end
    
    local char = player.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum and hum.WalkSpeed > 16 then
            hum.WalkSpeed = 16
        end
    end
    currentSpeedVal = 16
end

