local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local hiddenfling = false
local flingPower = 10000
local flingHeight = 30
local flingSpeed = 120
local targetPosition = Vector3.zero
local lp = Players.LocalPlayer
local powerDragging = false
local heightDragging = false
local speedDragging = false

if not ReplicatedStorage:FindFirstChild("juisdfj0i32i0eidsuf0iok") then
	local detection = Instance.new("Decal")
	detection.Name = "juisdfj0i32i0eidsuf0iok"
	detection.Parent = ReplicatedStorage
end

local function setSliderPosition(slider, value, minValue, maxValue)
	local alpha = math.clamp((value - minValue) / (maxValue - minValue), 0, 1)
	slider.Position = UDim2.new(alpha, 0, 0, 0)
end

local function syncTargetPosition()
	local x = tonumber(PosXBox.Text)
	local y = tonumber(PosYBox.Text)
	local z = tonumber(PosZBox.Text)
	if x and y and z then
		targetPosition = Vector3.new(x, y, z)
	end
end

local function setTargetPosition(pos)
	targetPosition = pos
	PosXBox.Text = tostring(math.floor(pos.X + 0.5))
	PosYBox.Text = tostring(math.floor(pos.Y + 0.5))
	PosZBox.Text = tostring(math.floor(pos.Z + 0.5))
end

local function fling()
	local hrp, c, movel = nil, nil, 0.1
	
	while true do
		RunService.Heartbeat:Wait()
		if hiddenfling then
			while hiddenfling and not (c and c.Parent and hrp and hrp.Parent) do
				RunService.Heartbeat:Wait()
				c = lp.Character
				hrp = c and c:FindFirstChild("HumanoidRootPart")
			end

			if hiddenfling then
				local target = Vector3.new(targetPosition.X, targetPosition.Y + flingHeight, targetPosition.Z)
				local delta = target - hrp.Position
				local flatDelta = Vector3.new(delta.X, 0, delta.Z)
				local horizontalVelocity = Vector3.zero

				if flatDelta.Magnitude > 0.5 then
					horizontalVelocity = flatDelta.Unit * flingSpeed
				end

				hrp.Velocity = Vector3.new(horizontalVelocity.X, flingPower + math.clamp(delta.Y, -flingHeight, flingHeight), horizontalVelocity.Z)
				RunService.RenderStepped:Wait()
				if c and c.Parent and hrp and hrp.Parent then
					hrp.Velocity = Vector3.new(horizontalVelocity.X, 0, horizontalVelocity.Z)
				end
				RunService.Stepped:Wait()
				if c and c.Parent and hrp and hrp.Parent then
					hrp.Velocity = Vector3.new(horizontalVelocity.X, movel, horizontalVelocity.Z)
					movel = movel * -1
				end
			end
		end
	end
end

