local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local hiddenfling = false
local flingPower = 10000
local flingHeight = 30
local flingSpeed = 120
local targetPosition = Vector3.zero
local lp = Players.LocalPlayer

if not ReplicatedStorage:FindFirstChild("juisdfj0i32i0eidsuf0iok") then
	local detection = Instance.new("Decal")
	detection.Name = "juisdfj0i32i0eidsuf0iok"
	detection.Parent = ReplicatedStorage
end

local function getHumanoid()
	local character = lp.Character
	return character and character:FindFirstChildOfClass("Humanoid")
end

local function applySettingsFromBoxes()
	local newPower = tonumber(PowerBox.Text)
	local newHeight = tonumber(HeightBox.Text)
	local newSpeed = tonumber(SpeedBox.Text)

	if newPower then
		flingPower = math.clamp(math.floor(newPower), 1000, 100000)
	end
	if newHeight then
		flingHeight = math.clamp(math.floor(newHeight), 0, 300)
	end
	if newSpeed then
		flingSpeed = math.clamp(math.floor(newSpeed), 0, 500)
	end

	PowerBox.Text = tostring(flingPower)
	HeightBox.Text = tostring(flingHeight)
	SpeedBox.Text = tostring(flingSpeed)
	PowerLabel.Text = "Fling Power: " .. flingPower
	HeightLabel.Text = "Height: " .. flingHeight
	SpeedLabel.Text = "Speed: " .. flingSpeed
end

local function syncTargetPosition()
	local x = tonumber(PosXBox.Text)
	local y = tonumber(PosYBox.Text)
	local z = tonumber(PosZBox.Text)
	if x and y and z then
		targetPosition = Vector3.new(x, y, z)
	end
end

local function setTargetPosition(pos)
	targetPosition = pos
	PosXBox.Text = tostring(math.floor(pos.X + 0.5))
	PosYBox.Text = tostring(math.floor(pos.Y + 0.5))
	PosZBox.Text = tostring(math.floor(pos.Z + 0.5))
end

local function fling()
	local hrp, c, movel = nil, nil, 0.1
	local arriveRadius = 12
	
	while true do
		RunService.Heartbeat:Wait()
		if hiddenfling then
			while hiddenfling and not (c and c.Parent and hrp and hrp.Parent) do
				RunService.Heartbeat:Wait()
				c = lp.Character
				hrp = c and c:FindFirstChild("HumanoidRootPart")
			end

			if hiddenfling then
				local humanoid = getHumanoid()
				if humanoid then
					humanoid.Sit = true
				end

				local target = targetPosition
				local delta = target - hrp.Position
				local flatDelta = Vector3.new(delta.X, 0, delta.Z)
				local horizontalVelocity = Vector3.zero

				if flatDelta.Magnitude <= arriveRadius then
					hiddenfling = false
					ToggleButton.Text = "OFF"
					ToggleButton.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
					if humanoid then
						humanoid.Sit = false
					end
					hrp.Velocity = Vector3.zero
					continue
				end

				if flatDelta.Magnitude > 0.5 then
					local throwSpeed = math.max(flingSpeed, math.min(flatDelta.Magnitude * 2.5, flingSpeed * 2))
					horizontalVelocity = flatDelta.Unit * throwSpeed
				end

				local verticalVelocity = flingHeight + flingPower * 0.15
				hrp.Velocity = Vector3.new(horizontalVelocity.X, verticalVelocity, horizontalVelocity.Z)
				RunService.RenderStepped:Wait()
				if c and c.Parent and hrp and hrp.Parent then
					hrp.Velocity = Vector3.new(horizontalVelocity.X, movel, horizontalVelocity.Z)
				end
				RunService.Stepped:Wait()
				if c and c.Parent and hrp and hrp.Parent then
					hrp.Velocity = Vector3.new(horizontalVelocity.X, -movel, horizontalVelocity.Z)
					movel = movel * -1
				end
			end
		else
			local humanoid = getHumanoid()
			if humanoid and humanoid.Sit then
				humanoid.Sit = false
			end
		end
	end
end

