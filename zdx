local originalAnimations = {}

local function removeAllAnimations()
    local char = player.Character
    if not char then return end
    
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    local animator = hum:FindFirstChildOfClass("Animator")
    if animator then
        for _, track in pairs(animator:GetPlayingAnimationTracks()) do
            pcall(function() track:Stop() end)
        end
    end
    
    local humanoidDesc = hum:FindFirstChild("HumanoidDescription")
    if humanoidDesc then
        if #originalAnimations == 0 then
            originalAnimations = {
                WalkAnim = humanoidDesc.WalkAnim,
                RunAnim = humanoidDesc.RunAnim,
                JumpAnim = humanoidDesc.JumpAnim,
                FallAnim = humanoidDesc.FallAnim,
