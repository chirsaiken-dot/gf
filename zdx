-- ========== ULTIMATE DESYNC ==========
local ownedParts = {}
local desyncHeartbeat = nil
local lastPosition = nil
local antiLagCount = 0

local function stealNetworkOwnership()
    local char = player.Character
    if not char or not desyncActive then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local parts = Workspace:GetPartBoundsInRadius(hrp.Position, 100)
    for _, part in pairs(parts) do
        if part:IsA("BasePart") and part ~= hrp and not ownedParts[part] then
            pcall(function()
                part:SetNetworkOwner(player)
                ownedParts[part] = true
            end)
        end
    end
end

local function preventLagBack()
    local char = player.Character
    if not char or not desyncActive then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local currentPos = hrp.Position
    
    if lastPosition then
        local distance = (currentPos - lastPosition).Magnitude
        if distance > 10 and distance < 60 then
            antiLagCount = antiLagCount + 1
            if antiLagCount >= 2 then
                hrp.CFrame = hrp.CFrame
                stealNetworkOwnership()
                antiLagCount = 0
            end
        else
            antiLagCount = math.max(0, antiLagCount - 0.5)
        end
    end
    
    lastPosition = currentPos
end

local function ultimateDesyncLoop()
    if not desyncActive then return end
    stealNetworkOwnership()
    preventLagBack()
end

