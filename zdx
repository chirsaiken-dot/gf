local dodgeEnabled = false
local dodgeRadius = 25
local dodgeSpeed = 120
local targetPosition = nil
local dodgeModes = {"FLY", "FLOAT TP", "NORMAL"}
local dodgeModeIndex = 1
local dodgeBusy = false
local lastDodgeTime = 0
local dodgeCooldown = 0.8

local function getCharacterParts()
	local character = LocalPlayer.Character
	if not character then
		return nil, nil
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	local hrp = character:FindFirstChild("HumanoidRootPart")
	return humanoid, hrp
end

local function getRightVector(flatDirection)
	if flatDirection.Magnitude <= 0.001 then
		return Vector3.new(1, 0, 0)
	end

	local unit = flatDirection.Unit
	return Vector3.new(-unit.Z, 0, unit.X)
end

local function setTargetPosition(position)
	targetPosition = position
	PosXBox.Text = tostring(math.floor(position.X + 0.5))
	PosYBox.Text = tostring(math.floor(position.Y + 0.5))
	PosZBox.Text = tostring(math.floor(position.Z + 0.5))
end

local function syncTargetPosition()
	local x = tonumber(PosXBox.Text)
	local y = tonumber(PosYBox.Text)
	local z = tonumber(PosZBox.Text)
	if x and y and z then
		targetPosition = Vector3.new(x, y, z)
	end
end

local function applySettings()
	local newRadius = tonumber(RadiusBox.Text)
	local newSpeed = tonumber(SpeedBox.Text)

	if newRadius then
		dodgeRadius = math.clamp(math.floor(newRadius), 5, 300)
	end
	if newSpeed then
		dodgeSpeed = math.clamp(math.floor(newSpeed), 10, 400)
	end

	RadiusBox.Text = tostring(dodgeRadius)
	SpeedBox.Text = tostring(dodgeSpeed)
end

local function getNearestThreatDistance(origin)
	local nearestDistance = math.huge

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character then
			local otherHrp = player.Character:FindFirstChild("HumanoidRootPart")
			local otherHumanoid = player.Character:FindFirstChildOfClass("Humanoid")
			if otherHrp and otherHumanoid and otherHumanoid.Health > 0 then
				local distance = (otherHrp.Position - origin).Magnitude
				if distance < nearestDistance then
					nearestDistance = distance
				end
			end
		end
	end

	if nearestDistance == math.huge then
		return nil
	end

	return nearestDistance
end

local function getGroundedPosition(goalPosition, character)
	local rayParams = RaycastParams.new()
	rayParams.FilterType = Enum.RaycastFilterType.Exclude
	rayParams.FilterDescendantsInstances = {character}

	local rayOrigin = goalPosition + Vector3.new(0, 80, 0)
	local rayResult = Workspace:Raycast(rayOrigin, Vector3.new(0, -200, 0), rayParams)
	if rayResult then
		return rayResult.Position + Vector3.new(0, 3, 0)
	end

	return goalPosition
end

local function moveCharacter(duration, stepFunction)
	local elapsed = 0
	while elapsed < duration do
		local _, hrp = getCharacterParts()
		if not hrp then
			return
		end

		local dt = RunService.Heartbeat:Wait()
		elapsed = elapsed + dt
		local alpha = math.clamp(elapsed / duration, 0, 1)
		stepFunction(hrp, alpha)
	end
end

local function doNormalDodge(startPosition, goalPosition)
	local distance = (goalPosition - startPosition).Magnitude
	local duration = math.clamp(distance / dodgeSpeed, 0.15, 1.5)

	moveCharacter(duration, function(hrp, alpha)
		local nextPosition = startPosition:Lerp(goalPosition, alpha)
		hrp.CFrame = CFrame.new(nextPosition)
		hrp.AssemblyLinearVelocity = Vector3.zero
	end)
end

local function doFlyDodge(startPosition, goalPosition)
	local flatDelta = Vector3.new(goalPosition.X - startPosition.X, 0, goalPosition.Z - startPosition.Z)
	local distance = flatDelta.Magnitude
	local duration = math.clamp(distance / dodgeSpeed, 0.3, 1.8)
	local rightVector = getRightVector(flatDelta)
	local arcHeight = math.clamp(distance * 0.28, 12, 26)
	local arcWidth = math.clamp(distance * 0.18, 5, 14)

	moveCharacter(duration, function(hrp, alpha)
		local basePosition = startPosition:Lerp(goalPosition, alpha)
		local heightOffset = math.sin(alpha * math.pi) * arcHeight
		local sideOffset = math.sin(alpha * math.pi) * arcWidth
		local nextPosition = basePosition + Vector3.new(0, heightOffset, 0) + rightVector * sideOffset
		hrp.CFrame = CFrame.new(nextPosition)
		hrp.AssemblyLinearVelocity = Vector3.zero
	end)
end

local function doFloatTpDodge(startPosition, goalPosition)
	local liftPosition = startPosition + Vector3.new(0, math.clamp(dodgeSpeed * 0.18, 14, 30), 0)

	moveCharacter(0.22, function(hrp, alpha)
		local nextPosition = startPosition:Lerp(liftPosition, alpha)
		hrp.CFrame = CFrame.new(nextPosition)
		hrp.AssemblyLinearVelocity = Vector3.zero
	end)

	local _, hrp = getCharacterParts()
	if hrp then
		hrp.CFrame = CFrame.new(goalPosition.X, liftPosition.Y, goalPosition.Z)
		hrp.AssemblyLinearVelocity = Vector3.zero
	end

	moveCharacter(0.12, function(currentHrp, alpha)
		local nextPosition = Vector3.new(goalPosition.X, liftPosition.Y + (goalPosition.Y - liftPosition.Y) * alpha, goalPosition.Z)
		currentHrp.CFrame = CFrame.new(nextPosition)
		currentHrp.AssemblyLinearVelocity = Vector3.zero
	end)
end

local function executeDodge()
	if dodgeBusy or not targetPosition then
		return
	end

	local humanoid, hrp = getCharacterParts()
	if not humanoid or not hrp then
		return
	end

	dodgeBusy = true
	lastDodgeTime = tick()

	local character = LocalPlayer.Character
	local goalPosition = getGroundedPosition(targetPosition, character)
	local startPosition = hrp.Position
	local mode = dodgeModes[dodgeModeIndex]

	if mode == "FLY" then
		doFlyDodge(startPosition, goalPosition)
	elseif mode == "FLOAT TP" then
		doFloatTpDodge(startPosition, goalPosition)
	else
		doNormalDodge(startPosition, goalPosition)
	end

	local _, endHrp = getCharacterParts()
	if endHrp then
		endHrp.AssemblyLinearVelocity = Vector3.zero
	end

	dodgeBusy = false
end

ToggleButton.MouseButton1Click:Connect(function()
	dodgeEnabled = not dodgeEnabled
	if dodgeEnabled then
		ToggleButton.Text = "GHOST DODGE: ON"
		ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
	else
		ToggleButton.Text = "GHOST DODGE: OFF"
		ToggleButton.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
	end
end)

ModeButton.MouseButton1Click:Connect(function()
	dodgeModeIndex = dodgeModeIndex + 1
	if dodgeModeIndex > #dodgeModes then
		dodgeModeIndex = 1
	end
	ModeButton.Text = "MODE: " .. dodgeModes[dodgeModeIndex]
end)

HideButton.MouseButton1Click:Connect(function()
	Frame.Visible = not Frame.Visible
end)

SetPosButton.MouseButton1Click:Connect(function()
	local _, hrp = getCharacterParts()
	if hrp then
		setTargetPosition(hrp.Position)
	end
end)

PosXBox.FocusLost:Connect(syncTargetPosition)
PosYBox.FocusLost:Connect(syncTargetPosition)
PosZBox.FocusLost:Connect(syncTargetPosition)
RadiusBox.FocusLost:Connect(applySettings)
SpeedBox.FocusLost:Connect(applySettings)

RunService.Heartbeat:Connect(function()
	if not dodgeEnabled or dodgeBusy or not targetPosition then
		return
	end

	if tick() - lastDodgeTime < dodgeCooldown then
		return
	end

	local _, hrp = getCharacterParts()
	if not hrp then
		return
	end

	local nearestThreatDistance = getNearestThreatDistance(hrp.Position)
	if nearestThreatDistance and nearestThreatDistance <= dodgeRadius then
		task.spawn(executeDodge)
	end
end)

applySettings()
